{
  "manifest_version": 2,
  "version": "0.1.0",
  "name": "ZotExtract",
  "description": "LLM-based information extraction from PDFs in Zotero. Developed within the NFDIxCS project.",
  "icons": {
    "48": "icon.svg"
  },
  "applications": {
    "zotero": {
      "id": "zotextract@nfdixcs.org",
      "strict_min_version": "6.999",
      "strict_max_version": "8.*",
      "update_url": "https://raw.githubusercontent.com/SamyAteia/ZotExtract/main/update.json"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "zotextract@nfdixcs.org",
      "strict_min_version": "115.0"
    }
  }
}
